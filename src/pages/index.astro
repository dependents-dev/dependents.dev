---
import App from "#app";
import GithubIcon from "#icons/github";
import Layout from "#layout";

const title = "dependents.dev";
const description = `dependents.dev - Analyze package dependents, downloads, and traffic across the ecosystem.`;
---

<Layout {title} {description}>
  <div class="max-w-6xl mx-auto p-4 md:p-8 relative">
    <header class="mb-10 text-center">
      <h1 class="text-4xl font-extrabold text-slate-800 dark:text-white mb-2">
        dependents.dev
      </h1>
      <p class="text-slate-600 dark:text-slate-400 italic">
        Analyze package dependents, downloads, and traffic across the ecosystem.
      </p>
    </header>
    <a
      href="/github"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="GitHub"
      class="hidden sm:block sm:absolute sm:top-3 sm:right-3 md:top-5 md:right-5 p-1.5 text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors"
    >
      <GithubIcon />
    </a>
    <App client:load />
  </div>
</Layout>
